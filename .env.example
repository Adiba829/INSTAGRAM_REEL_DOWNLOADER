# ─────────────────────────────────────────────
#  Instagram Reel Downloader — Environment Config
# ─────────────────────────────────────────────

# Set to "true" for verbose logging & hot-reload
DEBUG=false

# Comma-separated list of allowed CORS origins.
# Use "*" to allow all origins (not recommended in production).
ALLOWED_ORIGINS=http://localhost:3000,https://yourfrontend.com

# Maximum file size in megabytes that will be served (default: 500)
MAX_FILE_SIZE_MB=500

# Seconds before a download is considered timed out (default: 120)
DOWNLOAD_TIMEOUT=120
